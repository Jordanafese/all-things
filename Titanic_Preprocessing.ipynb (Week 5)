    {
      "cell_type": "markdown",
      "metadata": {
        "id": "7e59eb7c"
      },
      "source": [
        "**Reasoning**:\n",
        "The subtask requires generating new features: 'FamilySize', 'IsAlone', and 'Title'. I will calculate 'FamilySize' by summing 'sibsp', 'parch', and 1. 'IsAlone' will be derived from 'FamilySize'. For 'Title', since the 'name' column is not present in the `df_processed` (from seaborn's 'titanic' dataset), I will adapt by using the existing 'who' column as a simplified title feature, mapping 'man', 'woman', and 'child' to 'Mr', 'Mrs', and 'Master' respectively, which fulfills the spirit of simplifying titles. Finally, I will print the value counts for these new features.\n",
        "\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "1f66e4ee",
        "outputId": "3f934f54-8445-49d7-b1f2-b827c5328dd1"
      },
      "source": [
        "print(\"🏗️ Creating New Features...\\n\")\n",
        "\n",
        "# 1. Create FamilySize feature\n",
        "# FamilySize = Number of siblings/spouses + Number of parents/children + passenger themselves\n",
        "df_processed['FamilySize'] = df_processed['sibsp'] + df_processed['parch'] + 1\n",
        "print(f\"✅ Created 'FamilySize' feature\")\n",
        "print(f\"   Range: {df_processed['FamilySize'].min()} to {df_processed['FamilySize'].max()}\")\n",
        "\n",
        "# 2. Create IsAlone feature (1 if alone, 0 if with family)\n",
        "df_processed['IsAlone'] = (df_processed['FamilySize'] == 1).astype(int)\n",
        "print(f\"\\n✅ Created 'IsAlone' feature\")\n",
        "print(f\"   Alone passengers: {df_processed['IsAlone'].sum()}\")\n",
        "print(f\"   With family: {len(df_processed) - df_processed['IsAlone'].sum()}\")\n",
        "\n",
        "# 3. Extract Title from Name or adapt using 'who' column\n",
        "# The current dataset (from seaborn) does not have a 'name' column for direct title extraction.\n",
        "# Adapting to use the 'who' column as a simplified title feature.\n",
        "if 'name' in df_processed.columns:\n",
        "    df_processed['Title'] = df_processed['name'].str.extract(' ([A-Za-z]+)\\.', expand=False)\n",
        "    print(f\"\\n✅ Extracted 'Title' from 'name' column\")\n",
        "    print(f\"   Unique titles found: {df_processed['Title'].nunique()}\")\n",
        "\n",
        "    # Display title distribution before simplification\n",
        "    print(\"\\n📊 Title Distribution (before simplification):\")\n",
        "    print(df_processed['Title'].value_counts())\n",
        "\n",
        "    # Simplify titles by grouping rare ones (original mapping)\n",
        "    title_mapping = {\n",
        "        'Mr': 'Mr',\n",
        "        'Miss': 'Miss',\n",
        "        'Mrs': 'Mrs',\n",
        "        'Master': 'Master',\n",
        "        'Rev': 'Rare',\n",
        "        'Dr': 'Rare',\n",
        "        'Col': 'Rare',\n",
        "        'Major': 'Rare',\n",
        "        'Mlle': 'Miss',\n",
        "        'Mme': 'Mrs',\n",
        "        'Don': 'Rare',\n",
        "        'Dona': 'Rare',\n",
        "        'Lady': 'Rare',\n",
        "        'Countess': 'Rare',\n",
        "        'Jonkheer': 'Rare',\n",
        "        'Sir': 'Rare',\n",
        "        'Capt': 'Rare',\n",
        "        'Ms': 'Miss'\n",
        "    }\n",
        "\n",
        "    df_processed['Title'] = df_processed['Title'].map(title_mapping).fillna('Rare') # fillna to catch any unmapped titles\n",
        "    print(\"✅ Simplified titles into common categories\")\n",
        "    print(\"\\n📊 Simplified Title Distribution:\")\n",
        "    print(df_processed['Title'].value_counts())\n",
        "elif 'who' in df_processed.columns:\n",
        "    # Using 'who' as a simplified 'Title' due to the absence of a 'name' column.\n",
